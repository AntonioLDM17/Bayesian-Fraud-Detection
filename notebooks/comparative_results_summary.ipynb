# %% [markdown]
# # Comparative Results Summary
#
# This notebook loads the saved experiment outputs and creates compact
# comparison tables for all trained models.
#
# It focuses on:
# - predictive performance
# - probabilistic quality
# - calibration
# - efficiency (if available)

# %%
from pathlib import Path
import json
import pandas as pd
import matplotlib.pyplot as plt

FULL_EVAL_PATH = Path("experiments/full_evaluation.json")
MODEL_COMPARISON_PATH = Path("experiments/model_comparison_table.csv")
EFFICIENCY_PATH = Path("experiments/efficiency_results/efficiency_table.csv")

if not FULL_EVAL_PATH.exists():
    raise FileNotFoundError(
        f"Could not find results file at: {FULL_EVAL_PATH}\n"
        "Run the evaluation script first."
    )

with FULL_EVAL_PATH.open("r", encoding="utf-8") as f:
    results = json.load(f)

print("Loaded:", FULL_EVAL_PATH)

# %% [markdown]
# ## Raw evaluation table from full_evaluation.json

# %%
rows = []

for model_name, model_info in results["models"].items():
    for split_name in ["validation", "test"]:
        split_info = model_info[split_name]
        cls = split_info["classification_metrics"]
        prob = split_info["proper_scoring_rules"]
        cal = split_info["calibration_metrics"]

        rows.append(
            {
                "model": model_name,
                "split": split_name,
                "artifact_type": model_info.get("artifact_type", ""),
                "pr_auc": cls["pr_auc"],
                "roc_auc": cls["roc_auc"],
                "f1": cls["f1"],
                "precision": cls["precision"],
                "recall": cls["recall"],
                "nll": prob["nll"],
                "brier_score": prob["brier_score"],
                "ece": cal["ece"],
                "mce": cal["mce"],
                "selected_threshold_from_validation": model_info.get(
                    "selected_threshold_from_validation"
                ),
            }
        )

df = pd.DataFrame(rows)
df.head()

# %% [markdown]
# ## Compact table for the test split

# %%
test_df = df[df["split"] == "test"].copy()
test_df = test_df.sort_values(
    by=["pr_auc", "f1", "nll"],
    ascending=[False, False, True],
)

compact_cols = [
    "model",
    "artifact_type",
    "pr_auc",
    "roc_auc",
    "f1",
    "precision",
    "recall",
    "nll",
    "brier_score",
    "ece",
    "selected_threshold_from_validation",
]

compact_table = test_df[compact_cols].reset_index(drop=True)
compact_table.style.format(
    {
        "pr_auc": "{:.4f}",
        "roc_auc": "{:.4f}",
        "f1": "{:.4f}",
        "precision": "{:.4f}",
        "recall": "{:.4f}",
        "nll": "{:.4f}",
        "brier_score": "{:.4f}",
        "ece": "{:.4f}",
        "selected_threshold_from_validation": "{:.4f}",
    }
)

# %% [markdown]
# ## Validation vs test side by side

# %%
pivot_table = df.pivot(
    index="model",
    columns="split",
    values=["pr_auc", "f1", "recall", "nll", "brier_score", "ece"],
)
pivot_table = pivot_table.sort_values(by=("pr_auc", "test"), ascending=False)
pivot_table.style.format("{:.4f}")

# %% [markdown]
# ## Load model_comparison_table.csv if available

# %%
comparison_df = None

if MODEL_COMPARISON_PATH.exists():
    comparison_df = pd.read_csv(MODEL_COMPARISON_PATH)
    print("Loaded:", MODEL_COMPARISON_PATH)
    display(comparison_df.head())
else:
    print("model_comparison_table.csv not found yet.")

# %% [markdown]
# ## Load efficiency_table.csv if available

# %%
efficiency_df = None

if EFFICIENCY_PATH.exists():
    efficiency_df = pd.read_csv(EFFICIENCY_PATH)
    print("Loaded:", EFFICIENCY_PATH)
    display(efficiency_df.head())
else:
    print("efficiency_table.csv not found yet.")

# %% [markdown]
# ## Merge comparison + efficiency if both are available

# %%
merged_df = None

if comparison_df is not None and efficiency_df is not None:
    merge_cols = [
        "model",
        "artifact_size_mb",
        "training_time_seconds",
        "load_time_seconds",
        "inference_time_total_seconds",
        "latency_ms_per_sample",
        "mc_samples_used",
    ]
    available_cols = [c for c in merge_cols if c in efficiency_df.columns]

    merged_df = comparison_df.merge(
        efficiency_df[available_cols],
        on="model",
        how="left",
    )
    display(merged_df.head())
else:
    print("Merged table not built because one of the inputs is missing.")

# %% [markdown]
# ## Quick visual comparison — PR-AUC

# %%
plot_df = compact_table.copy()
plot_df = plot_df.sort_values("pr_auc", ascending=False)

plt.figure(figsize=(8, 4.5))
plt.bar(plot_df["model"], plot_df["pr_auc"])
plt.xticks(rotation=25, ha="right")
plt.ylabel("PR-AUC")
plt.title("Test PR-AUC by model")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Quick visual comparison — ECE

# %%
plot_df = compact_table.copy()
plot_df = plot_df.sort_values("ece", ascending=True)

plt.figure(figsize=(8, 4.5))
plt.bar(plot_df["model"], plot_df["ece"])
plt.xticks(rotation=25, ha="right")
plt.ylabel("ECE")
plt.title("Test ECE by model (lower is better)")
plt.tight_layout()
plt.show()

# %% [markdown]
# ## Quick visual comparison — latency (if available)

# %%
if merged_df is not None and "latency_ms_per_sample" in merged_df.columns:
    plot_df = merged_df.dropna(subset=["latency_ms_per_sample"]).copy()
    plot_df = plot_df.sort_values("latency_ms_per_sample", ascending=True)

    plt.figure(figsize=(8, 4.5))
    plt.bar(plot_df["model"], plot_df["latency_ms_per_sample"])
    plt.xticks(rotation=25, ha="right")
    plt.ylabel("Latency (ms/sample)")
    plt.title("Inference latency by model")
    plt.tight_layout()
    plt.show()
else:
    print("Latency plot skipped because efficiency results are not available.")

# %% [markdown]
# ## Export compact test table

# %%
output_csv = Path("experiments/model_comparison_table_from_notebook.csv")
compact_table.to_csv(output_csv, index=False)
print(f"Saved compact comparison table to: {output_csv}")